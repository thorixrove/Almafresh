{
  "expo": {
    "name": "almafresh",
    "slug": "almafresh",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "almafresh",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",

      },
      "predictiveBackGestureEnabled": false,
      "package": "com.thorixrover.almafresh"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "@clerk/expo",
      "expo-router",
      [
        "expo-splash-screen",
        {
      "backgroundColor": "#208AEF",
      "image": "./assets/images/icon.png",
      "imageWidth": 76
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
